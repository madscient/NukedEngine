; NukedEngineApi.def
; MSVC エクスポート定義ファイル。
; FmEngineApi.def と同一シンボルに加え NukedEngine 拡張を追加。

LIBRARY NukedEngineApi

EXPORTS
    FmEngine_Create
    FmEngine_Destroy
    FmEngine_AddChip
    FmEngine_AddExtChip
    FmEngine_GetChipName
    FmEngine_GetNativeRate
    FmEngine_GetSampleRate
    FmEngine_Write
    FmEngine_SetGain
    FmEngine_GetGain
    FmEngine_SetMemory
    FmEngine_GetMemorySize
    FmEngine_Generate
    FmEngine_AddNukedChip
