; NukedEngineApi.def
; MSVC エクスポート定義ファイル。
; FmEngineApi.def と同一シンボルに加え NukedEngine 拡張を追加。

LIBRARY NukedEngineApi

EXPORTS
    FmEngine_Create
    FmEngine_Destroy
    FmEngine_AddChip
    FmEngine_AddExtChip
    FmEngine_GetChipName
    FmEngine_GetNativeRate
    FmEngine_GetSampleRate
    FmEngine_Write
    FmEngine_SetGain
    FmEngine_GetGain
    FmEngine_SetMemory
    FmEngine_GetMemorySize
    FmEngine_Generate
    Wasapi_Create
    Wasapi_CreateWithDevice
    Wasapi_GetDeviceCount
    Wasapi_GetDeviceId
    Wasapi_GetDeviceName
    Wasapi_IsDefaultDevice
    Wasapi_Destroy
    Wasapi_Start
    Wasapi_Stop
    Wasapi_GetSampleRate
    FmEngine_AddNukedChip
